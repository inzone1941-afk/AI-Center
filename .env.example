# Google Gemini API Key (Required for chat features)
# Get one from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Home Assistant URL (Optional, defaults to supervisor inside Home Assistant)
# Example for local development: http://homeassistant.local:8123
HASS_URL=http://homeassistant.local:8123

# Home Assistant Long-Lived Access Token (Required if running standalone)
# Generate one in Home Assistant: User Profile -> Long-lived access tokens (at the bottom)
HASS_TOKEN=your_long_lived_access_token_here

# Port to run the server on
PORT=7682
